# .env.example - Copy to .env or .confluencerc and fill in your values.
# Lines starting with # are comments. Inline comments are also supported.
# Values may be quoted or unquoted. Do not commit credentials to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Base URL of your Confluence instance (no trailing slash)
CONFLUENCE_URL=https://yoursite.atlassian.net   # Cloud
# CONFLUENCE_URL=https://confluence.example.com  # Server / Data Center

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Authentication scheme: basic (default) or bearer
# CONFLUENCE_AUTH_TYPE=basic

# --- Cloud (basic auth) ---
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_TOKEN=your-atlassian-api-token

# --- Server / Data Center (basic auth) ---
# CONFLUENCE_USERNAME=your-username
# CONFLUENCE_TOKEN=your-personal-access-token   # preferred over password
# CONFLUENCE_PASSWORD=your-password             # fallback if no token

# --- Server / Data Center (bearer auth / PAT) ---
# CONFLUENCE_AUTH_TYPE=bearer
# CONFLUENCE_TOKEN=your-personal-access-token

# ---------------------------------------------------------------------------
# Instance type
# ---------------------------------------------------------------------------

# cloud (default) or server
# CONFLUENCE_TYPE=cloud

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

# Output format: md (default), html, or raw
# CONFLUENCE_FORMAT=md

# Directory where exported files are written (default: ./export)
# CONFLUENCE_OUTPUT_DIR=./export

# ---------------------------------------------------------------------------
# Behaviour
# ---------------------------------------------------------------------------

# Maximum number of API retry attempts on transient errors (default: 3)
# CONFLUENCE_MAX_RETRIES=3

# Base delay in seconds between retries — doubles on each attempt (default: 5)
# CONFLUENCE_RETRY_DELAY=5

# Set to 1 to enable verbose debug output
# CONFLUENCE_DEBUG=0
